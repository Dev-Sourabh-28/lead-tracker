generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  password    String
  createdAt   DateTime @default(now())
  portfolios Portfolio[]
}

model Portfolio {
  id           String   @id @default(cuid())
  title        String
  slug         String   @unique
  bio          String?
  theme        String   @default("minimal")

  userId       String
  user         User     @relation(fields: [userId], references: [id])

  projects     Project[]

  createdAt    DateTime @default(now())
}

model Project {
  id           String   @id @default(cuid())
  title        String
  description  String
  githubUrl    String?
  liveUrl      String?

  techStack    String[]

  imageUrl     String?

  portfolioId  String
  portfolio    Portfolio @relation(fields: [portfolioId], references: [id])

  createdAt    DateTime  @default(now())
}

